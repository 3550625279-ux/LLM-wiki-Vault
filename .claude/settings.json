{
  "env": {
    "VAULT_ROOT": ".",
    "WIKI_DIR": "wiki",
    "LOG_FILE": "log.md",
    "HOT_FILE": "wiki/hot.md",
    "INDEX_FILE": "wiki/concepts-idx.md"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(wiki/**)",
      "Write(scripts/**)",
      "Write(log.md)",
      "Edit(wiki/**)",
      "Edit(log.md)",
      "Glob(wiki/**)",
      "Grep(wiki/**)",
      "Bash(bash scripts/*.sh*)"
    ],
    "deny": [
      "Write(raw/**)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/post-session.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/log-write.sh 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "A file was just written to {file_path}. Check if this file is under wiki/concepts/ or wiki/sources/ AND has frontmatter type 'concept' or 'source'. If both conditions are met AND the file does NOT already have a 'thumbnail' field in frontmatter, run /flux-illustrate on this file. If the file already has a thumbnail or is not a concept/source page, do nothing."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-paper@claude-paper": true
  }
}
